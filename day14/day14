# 12. Declare categorize_countries pattern finder
def categorize_countries(country_list, pattern):
    return list(filter(lambda c: pattern.lower() in c.lower(), country_list))

# 13. Create a function returning a counts dictionary of starting letters
def count_starting_letters(country_list):
    counts = {}
    for c in country_list:
        start_letter = c[0].upper()
        counts[start_letter] = counts.get(start_letter, 0) + 1
    return counts

