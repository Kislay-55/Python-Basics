# 2. Sort out the ten most spoken languages
def ten_most_spoken_languages(data):
    lang_counts = {}
    for country in data:
        for lang in country['languages']:
            lang_counts[lang] = lang_counts.get(lang, 0) + 1
    
    # Sort by value count descending, slice top 10
    sorted_langs = sorted(lang_counts.items(), key=lambda x: x[1], reverse=True)
    return sorted_langs[:10]

# 3. Sort out the ten most populated countries
def ten_most_populated_countries(data):
    sorted_pop = sorted(data, key=lambda c: c['population'], reverse=True)
    return sorted_pop[:10]