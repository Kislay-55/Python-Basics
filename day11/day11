# 1. Check if number is prime
def is_prime(num):
    if num <= 1:
        return False
    for i in range(2, int(math.sqrt(num)) + 1):
        if num % i == 0:
            return False
    return True

# 2. Check if all items are unique
def all_items_unique(lst):
    return len(lst) == len(set(lst))

# 3. Check if all items are of the same data type
def all_same_type(lst):
    if not lst:
        return True
    first_type = type(lst[0])
    return all(type(item) == first_type for item in lst)

# 4. Check if a string is a valid Python variable name
def is_valid_variable(var_name):
    return str(var_name).isidentifier()

