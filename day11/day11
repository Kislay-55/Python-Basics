# 11. Add item to end of list
def add_item(lst, item):
    new_lst = lst.copy()
    new_lst.append(item)
    return new_lst

# 12. Remove item from list
def remove_item(lst, item):
    new_lst = lst.copy()
    if item in new_lst:
        new_lst.remove(item)
    return new_lst

# 13. Sum of numbers up to range
def sum_of_numbers(num):
    return sum(range(1, num + 1))

# 14. Sum of odds up to range
def sum_of_odds(num):
    return sum(i for i in range(1, num + 1) if i % 2 != 0)

# 15. Sum of evens up to range
def sum_of_even(num):
    return sum(i for i in range(1, num + 1) if i % 2 == 0)


