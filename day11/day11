def most_spoken_languages(countries_list, limit=10):
    lang_counter = Counter()
    for country in countries_list:
        for lang in country.get("languages", []):
            lang_counter[lang] += 1
    return lang_counter.most_common(limit)

def most_populated_countries(countries_list, limit=10):
    sorted_countries = sorted(countries_list, key=lambda x: x.get("population", 0), reverse=True)
    return [(c["name"], c["population"]) for c in sorted_countries[:limit]]


