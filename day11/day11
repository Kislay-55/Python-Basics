# 9. Reverse list using loops
def reverse_list(arr):
    reversed_arr = []
    for i in range(len(arr) - 1, -1, -1):
        reversed_arr.append(arr[i])
    return reversed_arr

# 10. Capitalize list items
def capitalize_list_items(lst):
