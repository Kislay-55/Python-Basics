# 4. Find the ten most spoken languages from the data
print("\n--- Ten Most Spoken Languages ---")
language_counts = {}
for country_item in countries_data:
    for lang in country_item['languages']:
        language_counts[lang] = language_counts.get(lang, 0) + 1

