# 1. Iterate 0 to 10 using for loop, do the same using while loop.
print("--- 0 to 10 (For Loop) ---")
for i in range(11):
    print(i)

print("\n--- 0 to 10 (While Loop) ---")
i = 0
while i <= 10:
    print(i)
    i += 1


# 2. Iterate 10 to 0 using for loop, do the same using while loop.
print("\n--- 10 to 0 (For Loop) ---")
for i in range(10, -1, -1):
    print(i)

print("\n--- 10 to 0 (While Loop) ---")
i = 10
while i >= 0:
    print(i)
    i -= 1


# 3. Write a loop that makes seven calls to print() to output a triangle
print("\n--- Triangle Pattern ---")
for i in range(1, 8):
    print('#' * i)


# 4. Use nested loops to create the specified grid pattern
print("\n--- Grid Pattern ---")
for i in range(8):
    for j in range(8):
        print('#', end=' ')
    print()


# 5. Print the multiplication pattern
print("\n--- Multiplication Pattern ---")
for i in range(11):
    print(f"{i} x {i} = {i * i}")


# 6. Iterate through the tech list using a for loop
print("\n--- Tech List Iteration ---")
techs = ['Python', 'Numpy', 'Pandas', 'Django', 'Flask']
for tech in techs:
    print(tech)


# 7. Use for loop to iterate from 0 to 100 and print only even numbers
print("\n--- Even Numbers (0 to 100) ---")
for i in range(0, 101, 2):
    print(i)


# 8. Use for loop to iterate from 0 to 100 and print only odd numbers
print("\n--- Odd Numbers (0 to 100) ---")
for i in range(1, 101, 2):
    print(i)


