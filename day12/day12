# 1. Generate a six-digit/character random user ID
def random_user_id():
    # Uses lowercase letters and digits to match the '1ee33d' example
    characters = string.ascii_lowercase + string.digits
    return ''.join(random.choice(characters) for _ in range(6))


# 2. Dynamic user ID generation based on user inputs
def user_id_gen_by_user():
    # Prompt the user for dimensions
    char_count = int(input("Enter the number of characters per ID: "))
    id_count = int(input("Enter the number of IDs to generate: "))
    
    # Mix of uppercase, lowercase letters, and digits to match your example outputs
    pool = string.ascii_letters + string.digits
    
    generated_ids = []
    for _ in range(id_count):
        single_id = ''.join(random.choice(pool) for _ in range(char_count))
        generated_ids.append(single_id)
        
    # Return as a multiline string for readable console output
    return '\n'.join(generated_ids)


# 3. Generate a single RGB color string
def rgb_color_gen():
    r = random.randint(0, 255)
    g = random.randint(0, 255)
    b = random.randint(0, 255)
    return f"rgb({r},{g},{b})"


