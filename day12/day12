# 1. Shuffle a list and return the shuffled result
def shuffle_list(lst):
    # Creating a copy prevents mutating the original list passed to the function
    shuffled = lst.copy()
    random.shuffle(shuffled)
    return shuffled


# 2. Return an array of 7 unique random numbers ranging from 0 to 9
def seven_unique_numbers():
    # random.sample guarantees uniqueness without needing loop checks
    return random.sample(range(10), 7)


