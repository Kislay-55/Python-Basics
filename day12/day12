# 1. Return an array of N hexadecimal colors
def list_of_hexa_colors(num_colors):
    hex_chars = '0123456789abcdef'
    colors = []
    for _ in range(num_colors):
        hex_color = '#' + ''.join(random.choice(hex_chars) for _ in range(6))
        colors.append(hex_color)
    return colors


# 2. Return an array of N RGB color strings
def list_of_rgb_colors(num_colors):
    colors = []
    for _ in range(num_colors):
        r = random.randint(0, 255)
        g = random.randint(0, 255)
        b = random.randint(0, 255)
        colors.append(f"rgb({r}, {g}, {b})")
    return colors


# 3. Combined color generator handling both types
def generate_colors(color_type, num_colors):
    if color_type.lower() == 'hexa':
        return list_of_hexa_colors(num_colors)
    elif color_type.lower() == 'rgb':
        return list_of_rgb_colors(num_colors)
    else:
        return "Invalid color type. Use 'hexa' or 'rgb'."


