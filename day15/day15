# SyntaxError Fix
print('hello world')

# NameError Fix
age = 25
print(age)

# IndexError Fix
numbers = [1, 2, 3, 4, 5]
print(numbers[4])

# ModuleNotFoundError and AttributeError Fix
import math
print(math.pi)

# KeyError Fix
user = {'name': 'Asab', 'age': 250, 'country': 'Finland'}
print(user['country'])

# TypeError Fix
print(4 + int('3'))

# ImportError Fix
from math import pow
print(pow(2, 3))

# ValueError Fix
print(int('12'))

# ZeroDivisionError Fix
print(1 / 2)